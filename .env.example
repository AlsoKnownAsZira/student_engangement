# ═══════════════════════════════════════════════════════════════════
# Engagement Analyzer — Environment Variables (V10 pipeline)
# Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-public-key
SUPABASE_SERVICE_KEY=your-service-role-key

# ── JWT (copy from Supabase → Settings → API → JWT Secret) ──────
JWT_SECRET=your-jwt-secret

# ── Model paths (relative to project root) ───────────────────────
# V10 = 2-stage pipeline:
#   DETECTION: bbox per orang (output class diabaikan, hanya untuk tracking)
#   CLASSIFIER: tiap crop bbox -> P(engaged)  (yolo11s-cls 224px)
DETECTION_MODEL_PATH=models/best_v5.pt
CLASSIFIER_MODEL_PATH=models/best_v10.pt

# ── Device ────────────────────────────────────────────────────────
# "auto" = GPU if available, else CPU.  "0" = force GPU.  "cpu" = force CPU.
DEVICE=auto

# ── Detector ──────────────────────────────────────────────────────
CONF_THRESHOLD=0.2
IOU_THRESHOLD=0.5

# ── Classifier (V10) ──────────────────────────────────────────────
# Threshold default dari per-session calibration V10 (test acc 82.21%).
# Untuk recalibrate ke sesi/kelas baru, jalankan phase3_training/calibrate_v10.py.
CLASSIFY_THRESHOLD=0.170
CLASSIFIER_IMGSZ=224

# ── Frame sampling ────────────────────────────────────────────────
# Source classroom video biasanya 15fps. Stride 5 = inferensi efektif 3fps.
FRAME_STRIDE=5
SMOOTHING_WINDOW=10

# ── Upload limits ────────────────────────────────────────────────
MAX_VIDEO_SIZE_MB=200

# ── Server ────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501
